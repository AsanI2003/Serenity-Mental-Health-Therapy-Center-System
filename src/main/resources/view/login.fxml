<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXPasswordField?>
<?import com.jfoenix.controls.JFXTextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="loginpane" prefHeight="519.0" prefWidth="687.0" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.serenity.controller.LoginController">
   <children>
      <ImageView fitHeight="519.0" fitWidth="788.0" layoutX="-79.0">
         <image>
            <Image url="@../Images/rm274batch2-baifernn-02.jpg" />
         </image>
      </ImageView>
      <Label layoutX="36.0" layoutY="35.0" text="Serenity Mental Health Therapy Center">
         <font>
            <Font size="38.0" />
         </font>
      </Label>
      <JFXTextField fx:id="userfield" layoutX="88.0" layoutY="191.0" prefHeight="36.0" prefWidth="217.0" promptText="Username">
         <font>
            <Font size="24.0" />
         </font></JFXTextField>
      <Button fx:id="loginbutton" layoutX="217.0" layoutY="376.0" mnemonicParsing="false" onAction="#onClick" prefHeight="36.0" prefWidth="87.0" text="Login">
         <font>
            <Font size="23.0" />
         </font></Button>
      <JFXPasswordField fx:id="passwordfield" layoutX="88.0" layoutY="303.0" prefHeight="36.0" prefWidth="217.0" promptText="Password">
         <font>
            <Font size="24.0" />
         </font></JFXPasswordField>
   </children>
