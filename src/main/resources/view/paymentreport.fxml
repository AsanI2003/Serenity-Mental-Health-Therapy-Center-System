<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.serenity.controller.PaymentReportController">
    <Label fx:id="totalPaymentsLabel" layoutX="50" layoutY="50" style="-fx-font-size: 18px;"/>
    <Label fx:id="totalIncomeLabel" layoutX="50" layoutY="100" style="-fx-font-size: 18px;"/>

    <Button text="Print" layoutX="50" layoutY="150" onAction="#handlePrint"/>
    <Button text="Close" layoutX="150" layoutY="150" onAction="#closeWindow"/>
</AnchorPane>
